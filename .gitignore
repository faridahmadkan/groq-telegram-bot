# Create .gitignore file
cat > .gitignore << 'EOF'
# Dependencies
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Environment variables
.env
.env.local
.env.production

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Logs
logs/
*.log

# Coverage directory used by tools like istanbul
coverage/

# Compiled output
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Bot specific
bot-session.json
user-data.json

# Render specific
.render/
EOF

# Add .gitignore to staging
git add .gitignore

# Update commit
git commit --amend --no-edit

# Push again
git push -u origin main --force